# 数据库配置。生产环境请使用专用低权限数据库用户，不要使用 root。
DATABASE_URL="mysql://macmima:change-this-password@localhost:3306/macmima"

# JWT配置
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="30d"
JWT_REFRESH_EXPIRES_IN="90d"

# 认证 pepper：只放服务器环境变量，不进数据库。生产环境请使用 32 字节以上随机值。
AUTH_PEPPER="generate-a-long-random-secret-with-openssl-rand-base64-32"
AUTH_ARGON2_MEMORY_KIB=19456
AUTH_ARGON2_TIME_COST=2
AUTH_ARGON2_PARALLELISM=1

# 服务器配置
PORT=3000
NODE_ENV="development"

# CORS配置
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"
