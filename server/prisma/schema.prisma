generator client {
  provider = "prisma-client-js"
  previewFeatures = ["fullTextIndex"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(uuid())
  workspaceKeyHash String?    @map("workspace_key_hash") @db.VarChar(64)
  username      String        @db.VarChar(50)
  email         String        @db.VarChar(100)
  displayName   String?       @map("display_name") @db.VarChar(60)
  avatarDataUrl String?       @map("avatar_data_url") @db.MediumText
  passwordHash  String        @map("password_hash") @db.VarChar(255)
  salt          String        @db.VarChar(64)
  isAdmin       Boolean       @default(false) @map("is_admin")
  sharedAccess  Boolean       @default(false) @map("shared_access")
  invitedBy     String?       @map("invited_by")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  lastLogin     DateTime?     @map("last_login")
  isActive      Boolean       @default(true) @map("is_active")

  credentials   Credential[]
  syncLogs      SyncLog[]
  inviteCodes   InviteCode[]
  chatMessages  WorkspaceChatMessage[]
  inviter       User?         @relation("UserInvites", fields: [invitedBy], references: [id])
  invitedUsers  User[]        @relation("UserInvites")

  @@index([email])
  @@index([username])
  @@index([invitedBy])
  @@index([workspaceKeyHash])
  @@unique([workspaceKeyHash, username])
  @@unique([workspaceKeyHash, email])
  @@map("users")
}

model InviteCode {
  id            String        @id @default(uuid())
  workspaceKeyHash String?    @map("workspace_key_hash") @db.VarChar(64)
  code          String        @unique @db.VarChar(32)
  createdBy     String        @map("created_by")
  usedBy        String?       @map("used_by")
  usedAt        DateTime?     @map("used_at")
  expiresAt     DateTime?     @map("expires_at")
  maxUses       Int           @default(1) @map("max_uses")
  currentUses   Int           @default(0) @map("current_uses")
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at")

  creator       User          @relation(fields: [createdBy], references: [id])

  @@index([code])
  @@index([createdBy])
  @@index([workspaceKeyHash])
  @@map("invite_codes")
}

model Credential {
  id            String              @id @default(uuid())
  userId        String              @map("user_id")
  workspaceKeyHash String?          @map("workspace_key_hash") @db.VarChar(64)
  scope         CredentialScope     @default(personal)
  category      CredentialCategory
  title         String              @db.VarChar(200)
  encryptedData String              @map("encrypted_data") @db.Text
  iv            String              @db.VarChar(32)
  authTag       String              @map("auth_tag") @db.VarChar(32)
  tags          Json?
  favorite      Boolean             @default(false)
  deleted       Boolean             @default(false)
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  lastUsed      DateTime?           @map("last_used")

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  history       CredentialHistory[]

  @@index([userId, category])
  @@index([userId, favorite])
  @@index([workspaceKeyHash, scope])
  @@fulltext([title])
  @@map("credentials")
}

model CredentialHistory {
  id            String     @id @default(uuid())
  credentialId  String     @map("credential_id")
  encryptedData String     @map("encrypted_data") @db.Text
  iv            String     @db.VarChar(32)
  authTag       String     @map("auth_tag") @db.VarChar(32)
  version       Int
  createdAt     DateTime   @default(now()) @map("created_at")

  credential    Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@index([credentialId, version])
  @@map("credential_history")
}

model SyncLog {
  id           String       @id @default(uuid())
  userId       String       @map("user_id")
  deviceId     String       @map("device_id") @db.VarChar(100)
  action       SyncAction
  status       SyncStatus
  errorMessage String?      @map("error_message") @db.Text
  syncedAt     DateTime     @default(now()) @map("synced_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, deviceId])
  @@map("sync_logs")
}

model WorkspaceChatMessage {
  id               String   @id @default(uuid())
  workspaceKeyHash String   @map("workspace_key_hash") @db.VarChar(64)
  userId           String   @map("user_id")
  content          String   @db.Text
  attachments      Json?
  masked           Boolean  @default(false)
  deleted          Boolean  @default(false)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceKeyHash, createdAt])
  @@index([userId])
  @@map("workspace_chat_messages")
}

enum CredentialCategory {
  server
  website
  api_key
  database
  document
  other
}

enum CredentialScope {
  personal
  shared
}

enum SyncAction {
  pull
  push
}

enum SyncStatus {
  success
  failed
}
